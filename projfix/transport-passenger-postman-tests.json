        {
          "name": "04 - Register duplicate email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/auth/register",
            "description": "Acceso: PUBLICO. Debe fallar con 409 si el email ya existe.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"otro_{{userUsername}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status 409 Conflict\", function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test(\"Mensaje de email duplicado\", function () {",
